#!/bin/bash

# ==============================================================================
# AUTOMATED ELK STACK INSTALLATION SCRIPT (Elasticsearch, Logstash, Kibana)
# Optimized for: 12 Cores / 8GB RAM
# Credentials: username "elastic", password "elastic"
# ==============================================================================

# 1. Check for Root
if [ "$EUID" -ne 0 ]; then
  echo "Please run as root (sudo ./install_elk.sh)"
  exit
fi

echo ">>> Updating System and Installing Dependencies..."
apt-get update
apt-get install -y apt-transport-https curl gnupg openjdk-17-jre-headless

# 2. Add Elastic Repository (Version 8.x - Latest)
echo ">>> Adding Elastic GPG Key and Repository..."
curl -fsSL https://artifacts.elastic.co/GPG-KEY-elasticsearch | gpg --dearmor -o /usr/share/keyrings/elastic.gpg --yes
echo "deb [signed-by=/usr/share/keyrings/elastic.gpg] https://artifacts.elastic.co/packages/8.x/apt stable main" | tee /etc/apt/sources.list.d/elastic-8.x.list

apt-get update

# 3. Install Components
echo ">>> Installing Elasticsearch, Logstash, and Kibana..."
apt-get install -y elasticsearch logstash kibana

# 4. Configure Elasticsearch
echo ">>> Configuring Elasticsearch..."

# Set JVM Heap to 4GB (50% of your 8GB RAM)
cat <<EOF > /etc/elasticsearch/jvm.options.d/heap.options
-Xms4g
-Xmx4g
EOF

# Configure elasticsearch.yml
# - Enable Security
# - Disable HTTP SSL (Simplifies curl/browser access for internal VMs)
# - Bind to 0.0.0.0 to allow external access
cat <<EOF > /etc/elasticsearch/elasticsearch.yml
cluster.name: my-elk-cluster
node.name: node-1
path.data: /var/lib/elasticsearch
path.logs: /var/log/elasticsearch
network.host: 0.0.0.0
http.port: 9200
discovery.type: single-node
xpack.security.enabled: true
xpack.security.enrollment.enabled: true
xpack.security.http.ssl:
  enabled: false
xpack.security.transport.ssl:
  enabled: true
  verification_mode: certificate
  keystore.path: certs/transport.p12
  truststore.path: certs/transport.p12
EOF

# 5. Start Elasticsearch
echo ">>> Starting Elasticsearch (This may take a minute)..."
systemctl daemon-reload
systemctl enable elasticsearch
systemctl start elasticsearch

# Wait for Elasticsearch to be responsive
echo ">>> Waiting for Elasticsearch to start on port 9200..."
until curl -s http://localhost:9200 > /dev/null; do
    sleep 5
    echo "Waiting..."
done

# 6. Set Password to "elastic"
echo ">>> Setting password for user 'elastic'..."

# We reset the password to a random one first to ensure the account is active/accessible
# Then we use the API to set it to your desired password "elastic"
TEMP_PASS=$(echo "y" | /usr/share/elasticsearch/bin/elasticsearch-reset-password -u elastic -a --url http://localhost:9200 | grep "New value" | awk '{print $NF}')

curl -X POST -u elastic:$TEMP_PASS -H "Content-Type: application/json" \
http://localhost:9200/_security/user/elastic/_password \
-d '{"password":"elastic"}'

echo -e "\n>>> Password set to 'elastic'"

# 7. Configure Kibana
echo ">>> Configuring Kibana..."
cat <<EOF > /etc/kibana/kibana.yml
server.port: 5601
server.host: "0.0.0.0"
elasticsearch.hosts: ["http://localhost:9200"]
elasticsearch.username: "elastic"
elasticsearch.password: "elastic"
EOF

systemctl enable kibana
systemctl start kibana

# 8. Configure Logstash (Optional Basic Config)
echo ">>> Configuring Logstash..."
systemctl enable logstash
systemctl start logstash

# 9. Firewall (Optional - Un-comment if you use UFW)
# ufw allow 9200/tcp
# ufw allow 5601/tcp
# ufw allow 5044/tcp

echo "========================================================"
echo "INSTALLATION COMPLETE!"
echo "========================================================"
echo "Access Kibana at: http://<YOUR_VM_IP>:5601"
echo "Login:"
echo "  Username: elastic"
echo "  Password: elastic"
echo "========================================================"
